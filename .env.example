# Shared backend and database defaults.
#
# For local Docker PostgreSQL:
#   leave the defaults as-is and run `docker compose up -d`.
#
# For Supabase Postgres:
#   replace SPRING_DATASOURCE_URL with your Supabase connection string, for example:
#   jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/smart_logistics
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

POSTGRES_DB=smart_logistics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5433

JWT_SECRET=ChangeThisSecretKeyToSomethingStrongAndLong!
JWT_EXPIRATION_MS=28800000
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
SERVER_PORT=8080

# Frontend API endpoint.
VITE_API_BASE_URL=http://localhost:8080